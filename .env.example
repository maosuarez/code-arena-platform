# ─────────────────────────────────────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017
MONGO_DB=code_arena

# ─────────────────────────────────────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esta-clave-en-produccion
VALIDATION_CODE=codigo-secreto-del-organizador

# CORS — orígenes permitidos separados por coma.
# Modo proxy: dejar vacío (el browser nunca llama directo al backend).
# Modo directo: poner la URL pública del frontend.
CORS_ORIGINS=

# ─────────────────────────────────────────────────────────────────────────────
# Frontend — modo de conexión al backend
# ─────────────────────────────────────────────────────────────────────────────
#
# MODO PROXY (docker-compose, recomendado):
#   Solo se expone el frontend. El backend vive en la red interna de Docker.
#   - NEXT_PUBLIC_BASE_URL=/backend       ← ruta relativa, baked en build
#   - BACKEND_INTERNAL_URL=http://backend:8000  ← usada por next.config.ts en runtime
#
# MODO DIRECTO (Azure SWA, o cuando quieres exponer el backend):
#   - NEXT_PUBLIC_BASE_URL=https://tu-backend.azurewebsites.net
#   - BACKEND_INTERNAL_URL=              ← vacío desactiva el rewrite proxy
#
NEXT_PUBLIC_BASE_URL=/backend
BACKEND_INTERNAL_URL=http://backend:8000
FRONTEND_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# EMQX MQTT Broker
# Solo funciona wss:// (TCP 1883/8883 no expuestos en el despliegue actual)
# ─────────────────────────────────────────────────────────────────────────────
MQTT_HOST=mqtt.tudominio.com
MQTT_WS_PORT=443
MQTT_WS_PATH=/mqtt
MQTT_USERNAME=code-arena-backend
MQTT_PASSWORD=cambia-esta-password-mqtt
MQTT_TOPIC_PREFIX=code-arena

# URL WSS para el cliente mqtt.js en el navegador (baked en build del frontend)
NEXT_PUBLIC_MQTT_WS_URL=wss://mqtt.maosuarez.com/mqtt
NEXT_PUBLIC_MQTT_TOPIC_PREFIX=code-arena
# Credenciales MQTT para el navegador. El broker EMQX exige auth: sin esto el
# cliente recibe "Not authorized". Idealmente usar un usuario solo-suscripción.
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Judge0 — sandbox de ejecución de código
# Instancia self-hosted: configurar AUTHN_TOKEN en judge0.conf del servidor.
# Si AUTHN_TOKEN está vacío en judge0.conf, dejar JUDGE0_API_KEY en blanco.
# ─────────────────────────────────────────────────────────────────────────────
JUDGE0_API_URL=https://judge0.maosuarez.com
JUDGE0_API_KEY=
